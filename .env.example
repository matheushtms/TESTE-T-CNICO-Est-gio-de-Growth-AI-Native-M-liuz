# Método 1 (Recomendado - Sem Google Cloud):
# Insira a URL obtida após implantar o Google Apps Script na planilha como App da Web
GOOGLE_WEB_APP_URL=sua_url_do_web_app_aqui

# Método 2 (Clássico - Com Google Cloud):
# ID da planilha (retirado da URL: https://docs.google.com/spreadsheets/d/ID_AQUI/edit)
GOOGLE_SHEET_ID=seu_sheet_id_aqui

# Caminho para o arquivo JSON de credenciais da Service Account
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

